PORT=3000

# SillyTavern 侧可选鉴权。设置后请求必须带 Authorization: Bearer <API_KEY>
API_KEY=change-me

# 在 PromptQL 控制台创建的 user token 或 bot token。
PROMPTQL_TOKEN=

# 从 URL https://prompt.ql.app/project/p-xxxx/room/general/feed 得到。
PROMPTQL_PROJECT_NAME=p-8969d7e6-d5df

# 角色扮演建议保持 true，避免把 SillyTavern 对话刷到 room feed。
PROMPTQL_ROOMLESS=true

# 只有 PROMPTQL_ROOMLESS=false 时才需要。
PROMPTQL_ROOM_NAME=general

# 通常不需要改。
PROMPTQL_CONTROL_GRAPHQL_ENDPOINT=https://data.pro.ql.app/v1/graphql
PROMPTQL_PLAYGROUND_HOST=https://playground.promptql.pro.hasura.io
# 如果 /ready 提示聊天端点不可用，就从浏览器 DevTools 里复制 start_thread 请求 URL 后填这里。
PROMPTQL_CHAT_GRAPHQL_ENDPOINT=
PROMPTQL_TIMEZONE=Asia/Shanghai
PROMPTQL_POLL_INTERVAL_MS=1200
PROMPTQL_TIMEOUT_MS=120000
PROMPTQL_REQUEST_TIMEOUT_MS=30000
PROMPTQL_MAX_EVENTS=200

# 可选：如果自动发现 build 失败，再手动填。
PROMPTQL_PROJECT_ID=
PROMPTQL_ROOM_ID=
PROMPTQL_BUILD_ID=
PROMPTQL_BUILD_FQDN=
PROMPTQL_VISIBILITY=
PROMPTQL_EXECUTION_MODE=
PROMPTQL_AGENT_RESPONSE_CONFIG=
